{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "strands-agentcore-workshop-agent",
  "description": "stands와 agentcore를 활용하여 ecommerce용 에이전트 빌드를 돕는 agent ",
  "prompt": "너는 AWS Strands SDK, AgendCore 에 대해 숙련된 경험자야. 사용자는 Ecommerce 용 리뷰 관리 시스템을 Agent 화 하려고 해. 이 agent를 strands 와 agentcore를 활용하여 개발 및 배포하려고 하니, 최대한 효율적이고 적절한 도구를 찾아서 실제 문법에 맞는 작업을 진행해줘. \n",
  "mcpServers": {
    "strands": {
      "command": "uvx",
      "args": [
        "strands-agents-mcp-server"
      ]
    }
  },
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "use_aws",
    "knowledge",
    "thinking",
    "todo_list",
    "introspect",
    "report_issue"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "use_aws",
    "thinking",
    "knowledge",
    "todo_list",
    "introspect",
    "report_issue"
  ],
  "toolsSettings": {},
  "resources": [
    "file://AmazonQ.md",
    "file://README.md",
    "file://.amazonq/rules/**/*.md",
    "file://.kiro/*"
  ],
  "hooks": {},
  "useLegacyMcpJson": true
}